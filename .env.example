# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=900
STALE_CACHE_TTL_SECONDS=86400
CACHE_FILE=src/storage/cache.json

# ─── Request / Rate Limit ────────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=12000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ─── Browser Fallback ────────────────────────────────────────────────────────
ENABLE_BROWSER_FALLBACK=true
CHROME_EXECUTABLE_PATH=

# ─── Instagram Session (REQUIRED for Stories) ────────────────────────────────
#
# This is how ALL competitor story viewer sites work.
# They use a real Instagram account's session cookie to access stories.
#
# Steps to get your sessionid:
#   1. Open Chrome — log into Instagram (use a new/spare account)
#   2. Press F12 → Application → Cookies → https://www.instagram.com
#   3. Find the cookie named "sessionid" → copy its Value
#   4. Also copy "ds_user_id" value
#   5. Paste both below
#
# The account does NOT need to follow anyone.
# Session lasts ~90 days. If stories stop loading, refresh it.
# Use a spare account — don't use your main account.
#
INSTAGRAM_SESSION_ID=
INSTAGRAM_DS_USER_ID=

# ─── Outbound Proxies (optional) ─────────────────────────────────────────────
# Format: http://user:pass@host:port,http://user:pass@host2:port
OUTBOUND_PROXIES=

# ─── Instagram Query Hashes (optional) ───────────────────────────────────────
INSTAGRAM_QUERY_HASHES=
INSTAGRAM_QUERY_IDS=
